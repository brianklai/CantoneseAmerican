# Public site URL used for canonicals, sitemap entries, Open Graph URLs, and feed URLs.
NEXT_PUBLIC_SITE_URL=https://cantoneseamerican.com

# Public media origin for externally hosted archive video, usually an R2 custom domain.
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.cantoneseamerican.com

# Optional public Facebook channel. If unset, Facebook is hidden gracefully.
FACEBOOK_URL=

# Local-only Cloudflare R2 credentials for scripts/upload-r2-media.mts.
# Do not expose these through NEXT_PUBLIC_* variables or browser code.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cantoneseamerican-media

# Keep the internal workflow board hidden in production unless explicitly enabled.
ENABLE_STUDIO=false

# Optional analytics webhook for privacy-respecting event forwarding.
# If unset, analytics events no-op in production and log locally in development.
ANALYTICS_WEBHOOK_URL=

# Configure at least one nomination delivery target in production.
SUBMISSION_WEBHOOK_URL=
RESEND_API_KEY=

# Submission email settings.
SUBMISSION_TO_EMAIL=speakingamericanorg@gmail.com
SUBMISSION_FROM_EMAIL=Cantonese American <onboarding@resend.dev>
